{
  "identity": {
    "host_id_override": null
  },
  "server": {
    "base_url": "http://127.0.0.1:8000",
    "heartbeat_path": "/api/v1/hosts/heartbeat",
    "request_timeout_seconds": 5.0
  },
  "schedule": {
    "interval_seconds": 15.0
  },
  "retry": {
    "max_attempts": 3,
    "initial_backoff_seconds": 1.0,
    "max_backoff_seconds": 5.0
  }
}
