{
  "target": {
    "service_name": "cron.service",
    "label": "Cron Scheduler"
  },
  "command": {
    "executable": "systemctl",
    "timeout_seconds": 5.0
  },
  "active": {
    "returncode": 0,
    "stdout": "LoadState=loaded\nActiveState=active\nSubState=running\n",
    "stderr": ""
  },
  "inactive": {
    "returncode": 0,
    "stdout": "LoadState=loaded\nActiveState=inactive\nSubState=dead\n",
    "stderr": ""
  },
  "failed": {
    "returncode": 0,
    "stdout": "LoadState=loaded\nActiveState=failed\nSubState=failed\n",
    "stderr": ""
  },
  "transitioning": {
    "returncode": 0,
    "stdout": "LoadState=loaded\nActiveState=activating\nSubState=start\n",
    "stderr": ""
  },
  "not_found": {
    "returncode": 4,
    "stdout": "LoadState=not-found\nActiveState=inactive\nSubState=dead\n",
    "stderr": "Unit cron.service could not be found."
  },
  "invalid_response": {
    "returncode": 0,
    "stdout": "LoadState=loaded\nActiveState=active\n",
    "stderr": ""
  }
}